---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const poems = (await getCollection("poems")).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const byYear = poems.reduce(
	(acc, poem) => {
		const year = poem.data.date.getFullYear();
		if (!acc[year]) acc[year] = [];
		acc[year].push(poem);
		return acc;
	},
	{} as Record<number, typeof poems>,
);

const years = Object.keys(byYear)
	.map(Number)
	.sort((a, b) => b - a);

const poemIds = poems.map((p) => p.id);
---

<Layout title="Poemas">
	<div class="pb-24 pt-10">
		<!-- Index header -->
		<div class="mb-6 flex items-baseline justify-between">
			<p class="font-mono text-[11px] uppercase tracking-widest text-muted">
				Índice de poemas
				<span class="ml-3 opacity-50">·</span>
				<span class="ml-3">{poems.length}</span>
			</p>
			<button
				id="random-poem"
				class="cursor-pointer font-mono text-[11px] uppercase tracking-widest text-muted transition-colors duration-200 hover:text-ink"
			>
				↯ Aleatorio
			</button>
		</div>

		<!-- Year navigation -->
		<nav class="mb-14 flex flex-wrap gap-5">
			{
				years.map((year) => (
					<a
						href={`#year-${year}`}
						class="font-mono text-[11px] tracking-widest text-muted transition-colors duration-200 hover:text-ink"
					>
						{year}
					</a>
				))
			}
		</nav>

		<!-- Year groups -->
		{
			years.map((year) => (
				<section id={`year-${year}`} class="mb-12">
					<!-- Year divider -->
					<div class="mb-5 flex items-center gap-4">
						<span class="font-mono text-[11px] tracking-widest text-muted">
							{year}
						</span>
						<div
							class="flex-1 border-t"
							style="border-color: color-mix(in srgb, var(--ink) 10%, transparent)"
						/>
					</div>

					<!-- Poem rows -->
					<ol class="m-0 list-none space-y-0 p-0">
						{byYear[year].map((poem) => (
							<li>
								<a
									href={`/poems/${poem.id}`}
									class="group dotted-leader border-b py-2.5 transition-colors duration-200"
									style="border-color: transparent"
									onmouseover="this.style.borderColor='color-mix(in srgb, var(--ink) 8%, transparent)'"
									onmouseout="this.style.borderColor='transparent'"
								>
									<span class="shrink-0 font-display text-[1.05rem] font-medium text-ink transition-colors duration-200 group-hover:text-sepia">
										{poem.data.title}
									</span>
									<span class="dotted-leader-dots" />
									<time
										datetime={poem.data.date.toISOString()}
										class="shrink-0 font-mono text-[11px] tabular-nums text-muted"
									>
										{poem.data.date.toLocaleDateString("es-ES", {
											day: "2-digit",
											month: "short",
										})}
									</time>
								</a>
							</li>
						))}
					</ol>
				</section>
			))
		}
	</div>
</Layout>

<script define:vars={{ poemIds }}>
	document.getElementById("random-poem")?.addEventListener("click", () => {
		const id = poemIds[Math.floor(Math.random() * poemIds.length)];
		window.location.href = `/poems/${id}`;
	});
</script>
