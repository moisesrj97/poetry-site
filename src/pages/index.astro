---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const poems = (await getCollection("poems")).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="Poems">
  <main>
    <ul>
      {poems.map((poem) => (
        <li>
          <a href={`/poems/${poem.id}`}>
            <span>{poem.data.title}</span>
            <time datetime={poem.data.date.toISOString()}>
              {poem.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {poem.data.description && <p>{poem.data.description}</p>}
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>
